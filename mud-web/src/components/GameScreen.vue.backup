<template>
  <div class="mud-android-screen" v-if="mud && mud.screen !== 'home'">
    <!-- 左侧对象列表 -->
    <div class="left-panel">
      <div class="target-list" v-if="mud.targets.length">
        <button class="target-btn" v-for="target in mud.targets" :key="target.key" @click="mud.sendTargetCmd(target)">
          <div v-html="target.labelHtml"></div>
        </button>
      </div>
    </div>

    <!-- 分隔线 -->
    <div class="divider-vertical"></div>

    <!-- 主内容区域 -->
    <div class="main-content">
      <!-- 顶部信息栏 -->
      <div class="top-bar">
        <div class="top-info" v-html="mud.topInfo || ''"></div>
      </div>

      <!-- 标题栏 -->
      <div class="title-bar">
        <div class="location-name">{{ mud.locationName || '当前位置' }}</div>
        <div class="title-buttons">
          <button class="title-btn" @click="mud.toggleStory">{{ mud.storyVisible ? '-' : '+' }}</button>
        </div>
      </div>

      <!-- 分隔线 -->
      <div class="divider-horizontal"></div>

      <!-- 故事描述区域 -->
      <div class="story-area" :class="{ hidden: !mud.storyVisible }">
        <div class="story-text" v-html="mud.storyHtml"></div>
      </div>

      <!-- 分隔线 -->
      <div class="divider-horizontal"></div>

      <!-- 主信息显示区 -->
      <div class="main-feed-area">
        <div class="feed-tabs">
          <button class="feed-tab" :class="{ active: mud.feedTab === 'main' }" @click="mud.feedTab = 'main'">主界面</button>
          <button class="feed-tab" :class="{ active: mud.feedTab === 'system' }" @click="mud.feedTab = 'system'">信息</button>
          <button class="feed-tab" :class="{ active: mud.feedTab === 'chat' }" @click="mud.feedTab = 'chat'">聊天</button>
          <button class="feed-tab" :class="{ active: mud.feedTab === 'fight' }" @click="mud.feedTab = 'fight'">战斗</button>
        </div>
        <div class="feed-content" ref="leftFeed" @click="mud.handleFeedClick" v-html="mud.activeFeedHtml"></div>
      </div>

      <!-- 分隔线 -->
      <div class="divider-horizontal"></div>

      <!-- 扩展命令区（方向按钮 + 自定义按钮） -->
      <div class="exits-area">
        <div class="exits-grid">
          <div class="exit-center">
            <button class="exit-btn center" @click="mud.sendCommand('look')">{{ mud.locationName || '观察' }}</button>
          </div>
          <button class="exit-btn n" v-show="hasExit('north')" @click="mud.sendCommand('north')">北</button>
          <button class="exit-btn s" v-show="hasExit('south')" @click="mud.sendCommand('south')">南</button>
          <button class="exit-btn w" v-show="hasExit('west')" @click="mud.sendCommand('west')">西</button>
          <button class="exit-btn e" v-show="hasExit('east')" @click="mud.sendCommand('east')">东</button>
          <button class="exit-btn nw" v-show="hasExit('northwest')" @click="mud.sendCommand('northwest')">西北</button>
          <button class="exit-btn ne" v-show="hasExit('northeast')" @click="mud.sendCommand('northeast')">东北</button>
          <button class="exit-btn sw" v-show="hasExit('southwest')" @click="mud.sendCommand('southwest')">西南</button>
          <button class="exit-btn se" v-show="hasExit('southeast')" @click="mud.sendCommand('southeast')">东南</button>
        </div>
        <div class="custom-cmds">
          <button class="cmd-btn" @click="mud.showCustomCmds = !mud.showCustomCmds">自定<br/>按钮</button>
          <button class="cmd-btn" v-for="(cmd, idx) in mud.customCmds.slice(0, 1)" :key="idx" @click="mud.sendCommand(cmd.cmd)">
            <span v-html="cmd.label || cmd.cmd"></span>
          </button>
        </div>
      </div>

      <!-- 自定义命令面板 -->
      <div class="custom-cmds-panel" v-show="mud.showCustomCmds">
        <div class="cmd-row">
          <button class="cmd-btn-small" v-for="(cmd, idx) in mud.customCmds.slice(0, 5)" :key="'row1-' + idx" @click="mud.sendCommand(cmd.cmd)" v-html="cmd.label || cmd.cmd"></button>
        </div>
        <div class="cmd-row">
          <button class="cmd-btn-small" v-for="(cmd, idx) in mud.customCmds.slice(5, 10)" :key="'row2-' + idx" @click="mud.sendCommand(cmd.cmd)" v-html="cmd.label || cmd.cmd"></button>
        </div>
      </div>

      <!-- 分隔线 -->
      <div class="divider-horizontal"></div>

      <!-- 底部菜单栏 -->
      <div class="bottom-menu">
        <button class="menu-icon-btn" @click="mud.toggleChatRoom" title="聊天">💬</button>
        <button class="menu-btn" @click="mud.sendCommand('score')">属性</button>
        <button class="menu-btn" @click="mud.sendCommand('i')">物品</button>
        <button class="menu-btn" @click="mud.sendCommand('skills')">技能</button>
        <button class="menu-btn" @click="mud.editCustomCmd(3)">长按<br/>修改</button>
        <button class="menu-btn" @click="mud.editCustomCmd(4)">长按<br/>修改</button>
        <button class="menu-btn" @click="mud.editCustomCmd(5)">长按<br/>修改</button>
        <button class="menu-icon-btn-right" @click="mud.openSettings" title="设置">⚙️</button>
      </div>
    </div>

    <!-- 聊天室弹窗 -->
    <div class="chat-overlay" v-show="mud.chatRoomVisible">
      <div class="chat-container">
        <div class="chat-tabs">
          <button class="chat-tab" :class="{ active: mud.chatTab === 'all' }" @click="mud.chatTab = 'all'">全部</button>
          <button class="chat-tab" :class="{ active: mud.chatTab === 'system' }" @click="mud.chatTab = 'system'">系统</button>
        </div>
        <div class="chat-content">
          <div class="chat-feed" v-html="mud.chatTab === 'all' ? mud.allChatHtml : mud.systemChatHtml"></div>
        </div>
        <div class="chat-bottom">
          <button class="close-chat-btn" @click="mud.toggleChatRoom">关 闭</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { inject, computed } from 'vue';

const mud = inject('mud');

const hasExit = (direction) => {
  return mud.exits && mud.exits.some(exit => exit.key === direction && exit.visible);
};
</script>

