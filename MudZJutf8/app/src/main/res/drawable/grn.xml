<?xml version="1.0" encoding="utf-8"?>
<selector
	xmlns:android="http://schemas.android.com/apk/res/android"
	>
	<item
		android:state_pressed="true"
		>
		<shape
			>
			<gradient
				android:startColor="#FF0D76E1"
				android:endColor="#FF0D76E1"
				android:angle="270.0"
				>
			</gradient>
			<stroke
				android:width="1.0dip"
				android:color="#FFF403C9"
				>
			</stroke>
			<corners
				android:radius="3.0dip"
				>
			</corners>
			<padding
				android:left="3.0dip"
				android:top="2.0dip"
				android:right="3.0dip"
				android:bottom="2.0dip"
				>
			</padding>
		</shape>
	</item>
	<item
		android:state_focused="true"
		>
		<shape
			>
			<gradient
				android:startColor="#FFFFC2B7"
				android:endColor="#FFFFC2B7"
				android:angle="270.0"
				>
			</gradient>
			<stroke
				android:width="1.0dip"
				android:color="#FFF403C9"
				>
			</stroke>
			<corners
				android:radius="3.0dip"
				>
			</corners>
			<padding
				android:left="3.0dip"
				android:top="2.0dip"
				android:right="3.0dip"
				android:bottom="2.0dip"
				>
			</padding>
		</shape>
	</item>
	<item
		>
		<shape
			>
			<gradient
				android:startColor="#9920E000"
				android:endColor="#99BBBBBB"
				android:angle="0.0"
				>
			</gradient>
			<corners
				android:radius="2.0dip"
				>
			</corners>
			<padding
				android:left="3.0dip"
				android:top="2.0dip"
				android:right="3.0dip"
				android:bottom="2.0dip"
				>
			</padding>
		</shape>
	</item>
</selector>
