<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:orientation="vertical"
	android:id="@+id/chongzhi_ck"
	android:background="#22000000"
	android:visibility="visible"
	android:clickable="true"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	>
	<LinearLayout
		android:orientation="vertical"
		android:id="@+id/LinearLayout1"
		android:background="#FFFFFFFF"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		>
		<LinearLayout
			android:gravity="center"
			android:orientation="horizontal"
			android:background="#FF4D586E"
			android:paddingTop="8.0dip"
			android:paddingBottom="8.0dip"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			>
			<Button
				android:textSize="15.0sp"
				android:textColor="#FFFFFFFF"
				android:id="@+id/gb_chongzhi"
				android:paddingTop="8.0dip"
				android:paddingBottom="8.0dip"
				android:layout_width="65.0dip"
				android:layout_height="35.0dip"
				android:layout_marginLeft="4.0dip"
				android:text="返回"
				>
			</Button>
			<TextView
				android:textSize="18.0sp"
				android:textColor="#FFFFFFFF"
				android:gravity="center"
				android:id="@+id/text_view"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="充值"
				android:layout_weight="1.0"
				>
			</TextView>
			<Button
				android:textSize="15.0sp"
				android:textColor="#FFFFFFFF"
				android:id="@+id/submitBtn"
				android:paddingTop="8.0dip"
				android:paddingBottom="8.0dip"
				android:layout_width="65.0dip"
				android:layout_height="35.0dip"
				android:layout_marginRight="4.0dip"
				android:text="付款"
				>
			</Button>
		</LinearLayout>
		<LinearLayout
			android:orientation="vertical"
			android:paddingLeft="10.0dip"
			android:paddingRight="10.0dip"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_weight="1.0"
			>
			<TextView
				android:textSize="17.0dip"
				android:textColor="#FF000000"
				android:id="@+id/now_pay_part"
				android:paddingLeft="5.0dip"
				android:layout_width="match_parent"
				android:layout_height="30.0dip"
				android:layout_marginTop="8.0dip"
				android:text="当前分区："
				>
			</TextView>
			<LinearLayout
				android:orientation="horizontal"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				>
				<TextView
					android:textSize="17.0dip"
					android:textColor="#FF000000"
					android:paddingLeft="5.0dip"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="游戏ＩＤ："
					>
				</TextView>
				<EditText
						android:textSize="15.0sp"
						android:textColor="#FF000000"
						android:id="@+id/pay_id"
						android:layout_width="match_parent"
						android:layout_height="35.0dip"
						android:layout_weight="1.0"
						android:imeOptions="normal">
				</EditText>
			</LinearLayout>
			<TextView
					android:textAppearance="@style/TextAppearance.AppCompat.Medium"
					android:textSize="11.0sp"
					android:textColor="#FFFF0000"
					android:id="@id/TextView02"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="  如果您的游戏ID跟用户中心账号不一致，请修改"
			>
			</TextView>
			<LinearLayout
				android:orientation="horizontal"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				>
				<TextView
					android:textSize="17.0dip"
					android:textColor="#FF000000"
					android:paddingLeft="5.0dip"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="充值金额："
					>
				</TextView>
				<EditText
						android:textSize="15.0sp"
						android:textColor="#FF000000"
						android:id="@+id/amount"
						android:layout_width="match_parent"
						android:layout_height="35.0dip"
						android:text="1"
						android:imeOptions="normal" android:inputType="number">
				</EditText>
			</LinearLayout>
			<LinearLayout
				android:background="#FFABABAB"
				android:layout_width="match_parent"
				android:layout_height="2.0dip"
				>
			</LinearLayout>
			<LinearLayout
				android:orientation="vertical"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:layout_weight="1.0"
				>
				<TextView
						android:textAppearance="@style/TextAppearance.AppCompat.Medium"
						android:textSize="13.0sp"
						android:textColor="#FF0000FF"
						android:id="@+id/TextView01"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="10.0dip"
						android:layout_marginBottom="5.0dip"
						android:text="  充值比例为 1元=10元宝"
				>
				</TextView>
				<LinearLayout
					android:background="#FFABABAB"
					android:layout_width="match_parent"
					android:layout_height="2.0dip"
					android:layout_marginTop="5.0dip"
					>
				</LinearLayout>
				<TextView
						android:textAppearance="@style/TextAppearance.AppCompat.Medium"
						android:textSize="13.0sp"
						android:textColor="#FFFF0000"
						android:id="@+id/textView1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="5.0dip"
						android:text="  注意：充值卡充值请务必在此输入正确面值！"
				>
				</TextView>
			</LinearLayout>
			<LinearLayout
				android:background="#FFABABAB"
				android:layout_width="match_parent"
				android:layout_height="2.0dip"
				>
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</RelativeLayout>
