<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:orientation="vertical"
	android:id="@+id/LinearLayout1"
	android:padding="0.0dip"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	>
	<com.zwyouto.myactivex.attrbar
		android:id="@+id/short_qi"
		android:layout_width="match_parent"
		android:layout_height="25.0dip"
		android:layout_weight="25.0"
		>
	</com.zwyouto.myactivex.attrbar>
	<com.zwyouto.myactivex.attrbar
		android:id="@+id/short_nei"
		android:layout_width="match_parent"
		android:layout_height="25.0dip"
		android:layout_weight="25.0"
		>
	</com.zwyouto.myactivex.attrbar>
	<TextView
		android:textSize="12.0sp"
		android:textStyle="normal"
		android:textColor="#FF00FF00"
		android:gravity="center"
		android:id="@+id/mytextimgname"
		android:background="@color/transparent"
		android:layout_width="match_parent"
		android:layout_height="30.0dip"
		android:layout_weight="30.0"
		>
	</TextView>
	<RelativeLayout
		android:gravity="center"
		android:id="@+id/short_img_zt"
		android:layout_width="match_parent"
		android:layout_height="90.0dip"
		android:layout_weight="90.0"
		>
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			>
			<ImageView
				android:id="@+id/short_img"
				android:padding="1.0dip"
				android:clickable="false"
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:scaleType="fitCenter"
				>
			</ImageView>
			<LinearLayout
				android:orientation="vertical"
				android:id="@+id/short_zt"
				android:paddingLeft="2.0dip"
				android:paddingRight="2.0dip"
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				>
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:orientation="vertical"
			android:id="@+id/fskills"
			android:layout_width="match_parent"
			android:layout_height="100.0dip"
			android:layout_centerInParent="true"
			>
		</LinearLayout>
	</RelativeLayout>
</LinearLayout>
